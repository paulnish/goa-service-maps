  "mandate_legend": [
    {
      "number": 1,
      "text": "Continue working with Travel Alberta to reach $25 billion in visitor spending target by 2035",
      "mapping": "-> Access Travel Alberta's destination marketing and visitor information; Invest in or develop a tourism product or experience"
    },
    {
      "number": 2,
      "text": "Implement the All-Season Resorts Act and expand resort development in Kananaskis, Crowsnest Pass, David Thompson, and Grande Cache",
      "mapping": "-> Propose an all-season resort development; Get information about all-season resort areas"
    },
    {
      "number": 3,
      "text": "Ensure full implementation of the Fairness and Safety in Sport Act using all available legal and constitutional tools",
      "mapping": "-> Get information about the Fairness and Safety in Sport Act; Comply with fairness and safety in sport requirements (organizations)"
    },
    {
      "number": 4,
      "text": "Create a provincial bidding policy for major sport events with transparent public disclosure and mandatory referenda for affected communities",
      "mapping": "-> Apply for a Major Sport Events grant"
    },
    {
      "number": 5,
      "text": "Work with Treasury Board and Finance to ensure visitors contribute fairly through taxes and fees",
      "mapping": "-> Register as a tourism levy collector; File and remit the tourism levy"
    }
  ]
