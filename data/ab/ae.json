  "mandate_legend": [
    {
      "number": 1,
      "text": "Accelerate credentialing for national and international workers — amend Fair Registration Practices Act",
      "mapping": "-> Get your trade credential recognized; Get your professional credentials recognized"
    },
    {
      "number": 2,
      "text": "Raise the status of trades as career paths starting in junior high",
      "mapping": "-> Explore careers in skilled trades; Access the Industry Pathways program"
    },
    {
      "number": 3,
      "text": "Develop faster K-12 teacher certification programs for degree/diploma holders and trades professionals",
      "mapping": "-> (Cross-ministry with Education and Childcare)"
    },
    {
      "number": 4,
      "text": "Review Expert Panel on Post-Secondary Institution Funding — ensure funding follows students",
      "mapping": "-> Fund and oversee post-secondary institutions"
    },
    {
      "number": 5,
      "text": "Introduce legislation to protect academic freedom and freedom of expression in post-secondary institutions",
      "mapping": "-> (System-wide policy)"
    },
    {
      "number": 6,
      "text": "Modernize intellectual property frameworks to ensure taxpayer benefit from commercialization",
      "mapping": "-> (System-wide policy)"
    },
    {
      "number": 7,
      "text": "Expand mental health professional spaces in post-secondary institutions ($10M over three years)",
      "mapping": "-> Support mental health on campus"
    },
    {
      "number": 8,
      "text": "Develop new physician training pathways with medical schools — focus on rural communities",
      "mapping": "-> (Cross-ministry with Health)"
    },
    {
      "number": 9,
      "text": "Implement the Professional Governance Act for non-health professional regulatory organizations",
      "mapping": "-> (System-wide policy)"
    },
    {
      "number": 10,
      "text": "Create non-repayable assistance for high school students entering fields with labour shortages",
      "mapping": "-> Apply for scholarships and awards; Apply for Alberta student loans and grants"
    }
  ]
}