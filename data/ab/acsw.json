    },
    {
      "number": 2,
      "text": "Promote Alberta's culture and heritage and grow Alberta Day as a province-wide celebration of our history and identity",
      "mapping": "-> Visit a provincial museum or historic site"
    },
    {
      "number": 3,
      "text": "Develop a new framework to repatriate Indigenous items held in provincial museum collections",
      "mapping": "-> Manage heritage policy and provincial collections"
    },
    {
      "number": 4,
      "text": "Work with the Minister of Children and Family Services to support domestic violence victims and strengthen prevention efforts",
      "mapping": "-> Call the family violence information line; Find family violence resources and supports; Coordinate strategy to prevent gender-based violence"
