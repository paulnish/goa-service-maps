                "estimate": "~30,000 reports/yr",
                "basis": "annual"
              },
              "economic_impact": {
                "tag": "Cost avoidance",
                "category": "cost_avoidance",
                "note": "Early identification prevents escalation to higher-cost interventions"
              },
              "channels": [
