  "mandate_legend": [
    {
      "number": 1,
      "text": "Overhaul property tax to ensure stability and fairness",
      "mapping": "-> Understand and pay your provincial property tax"
    },
    {
      "number": 2,
      "text": "Remove the gas tax, saving around 4 cents a litre at the pumps"
    },
    {
      "number": 3,
      "text": "Remove the provincial sales tax on electricity — 10% relief on home energy bills"
    },
    {
      "number": 4,
      "text": "Temporarily remove PST on new multi-unit housing construction"
    },
    {
      "number": 5,
      "text": "Balance the budget in each year of the mandate",
      "mapping": "-> Access the provincial budget and public accounts"
    },
    {
      "number": 6,
      "text": "Improve investment tax credits like SBITC and SR&ED for research, automation and technology"
    }
  ],
