  "mandate_legend": [
    {
      "number": 1,
      "text": "Create more medical training and residency seats with Dalhousie Medicine NB and CFMNB"
    },
    {
      "number": 2,
      "text": "Improve foreign credential recognition for healthcare professionals already in the province",
      "mapping": "-> Get your international credentials recognized"
    },
    {
      "number": 3,
      "text": "Continue to make provincial student loans interest-free",
      "mapping": "-> Apply for student financial assistance"
    },
    {
      "number": 4,
      "text": "Develop long-term student housing strategies with universities and colleges"
    },
    {
      "number": 5,
      "text": "Provide additional grants for students in healthcare, building trades and education"
    },
    {
      "number": 6,
      "text": "Focus immigration pathways on critical labour needs and support newcomers",
      "mapping": "-> Immigrate to New Brunswick through provincial immigration programs"
    },
    {
      "number": 7,
      "text": "Support unemployed and underemployed New Brunswickers to upskill",
      "mapping": "-> Get help finding a job and planning your career"
    },
    {
      "number": 8,
      "text": "Review and respond to the Systemic Racism Commissioner's final report"
    }
  ],
