  "mandate_date": "November 7, 2024",
  "mandate_minister": "Claire Johnson",
  "mandate_pdf": "https://www.gnb.ca/en/gov/contacts/members-executive-council/mandates-letters/mandates-johnson.html",
  "cross_cutting": [
    "Healthcare",
    "Affordability and Housing",
    "Education",
    "Economic Development",
    "Environment",
    "Leadership You Can Trust"
  ],
  "mandate_legend": [
    {
      "number": 1,
      "text": "Provide universal free breakfast and pay-what-you-can lunches in schools, using local NB food"
    },
    {
      "number": 2,
      "text": "Retain and recruit teachers, support professionals, EAs and bus drivers with better working conditions"
    },
    {
      "number": 3,
      "text": "Support inclusive education — review class composition and fill Policy 322 staffing and resource gaps",
      "mapping": "-> Get supports for your child's learning needs"
    },
    {
      "number": 4,
      "text": "Develop a fresh 10-year education plan with educators, experts and parents"
    },
    {
      "number": 5,
      "text": "Implement Child and Youth Advocate recommendations on Policy 713"
    },
    {
      "number": 6,
      "text": "Ensure adequate staffing and resources for literacy and numeracy classroom support"
    },
    {
      "number": 7,
      "text": "Continue grade 1 early French immersion entry and expand grade 6 access points",
      "mapping": "-> Choose a French second-language program for your child"
    },
    {
      "number": 8,
      "text": "Continue implementing $10-a-day child care across the province",
      "mapping": "-> Apply for help with child care costs"
    },
    {
      "number": 9,
      "text": "Reduce administrative and regulatory burden on child care operators",
      "mapping": "-> Get a licence to operate an early learning and child care facility"
    },
    {
      "number": 10,
      "text": "Eliminate the 4,000-child waitlist for affordable child care",
      "mapping": "-> Find licensed early learning and child care"
    }
  ],
