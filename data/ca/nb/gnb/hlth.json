  "mandate_legend": [
    {
      "number": 1,
      "text": "Establish 30 community care clinics offering collaborative care — 10 in the first 18 months",
      "mapping": "-> Find a primary care provider"
    },
    {
      "number": 2,
      "text": "Increase operating room hours to use hospitals to their fullest potential",
      "mapping": "-> Get hospital and specialty care"
    },
    {
      "number": 3,
      "text": "Establish a digital health office with centralized waitlists and standardized digital records"
    },
    {
      "number": 4,
      "text": "Recruit and retain healthcare professionals; expand scope of practice"
    },
    {
      "number": 5,
      "text": "Provide the RSV vaccine free for seniors and vulnerable people",
      "mapping": "-> Get immunized"
    },
    {
      "number": 6,
      "text": "Improve abortion access (amend regulation 84-20), make contraception free, expand midwifery, fund IVF"
    },
    {
      "number": 7,
      "text": "Make the public health office independent for unbiased, evidence-based decisions",
      "mapping": "-> Check public health alerts and advisories"
    },
    {
      "number": 8,
      "text": "Reduce mental health wait times below the national average",
      "mapping": "-> Access mental health services"
    },
    {
      "number": 9,
      "text": "Invest in treatment beds province-wide with a continuum of care after treatment",
      "mapping": "-> Access addiction treatment services"
    }
  ],
