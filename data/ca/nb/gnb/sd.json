  "mandate_legend": [
    {
      "number": 1,
      "text": "Increase social assistance rates and stop regulations penalizing recipients",
      "mapping": "-> Apply for social assistance"
    },
    {
      "number": 2,
      "text": "Let recipients participate in the workforce without losing benefits"
    },
    {
      "number": 3,
      "text": "Explore a basic income plan for New Brunswickers living with disabilities",
      "mapping": "-> Access disability support services"
    },
    {
      "number": 4,
      "text": "Fund transition homes and frontline domestic violence services sustainably"
    },
    {
      "number": 5,
      "text": "Fund safety and accessibility retrofits so seniors and people with disabilities can stay home"
    },
    {
      "number": 6,
      "text": "Provide Housing First wraparound services for chronic homelessness",
      "mapping": "-> Get help with emergency housing and homelessness"
    },
    {
      "number": 7,
      "text": "Introduce a 3% rent cap with a comprehensive Residential Tenancies Act update"
    },
    {
      "number": 8,
      "text": "Renovate public housing and build new units; support 30,000 new homes by 2030",
      "mapping": "-> Apply for public housing or a rent supplement"
    },
    {
      "number": 9,
      "text": "Expand Nursing Homes Without Walls so seniors can stay home longer",
      "mapping": "-> Get home support services"
    },
    {
      "number": 10,
      "text": "Implement a $250/month caregiver benefit for unpaid caregivers"
    },
    {
      "number": 11,
      "text": "Fill nursing home staffing gaps, raise PSW wages, increase hours of care",
      "mapping": "-> Get a long-term care needs assessment"
    }
  ],
