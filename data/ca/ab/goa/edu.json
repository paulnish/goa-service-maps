  "mandate_legend": [
    {
      "number": 1,
      "text": "Continue curriculum implementation with focus on literacy, numeracy, financial literacy, and practical life skills",
      "mapping": "-> Access curriculum resources and programs of study"
    },
    {
      "number": 2,
      "text": "Fast-track school construction through Schools Now program — $8.6B for 200,000+ new and updated student spaces",
      "mapping": "-> Enrol your child in school (infrastructure to support enrolment)"
    },
    {
      "number": 3,
      "text": "Develop expedited teacher certification for degree/diploma holders and skilled trades professionals",
      "mapping": "-> Apply for teacher certification; Transfer teaching credentials"
    },
    {
      "number": 4,
      "text": "Advance apprenticeship models and promote trades education at high school level",
      "mapping": "-> Explore career and technology studies (CTS); Access off-campus education (work experience, RAP)"
    },
    {
      "number": 5,
      "text": "Expand mental health supports for students in partnership with Mental Health and Addiction",
      "mapping": "-> Access school mental health supports"
    },
    {
      "number": 6,
      "text": "Implement Bill 27 protections and establish standards for school literary materials",
      "mapping": "-> (System-wide policy)"
    },
    {
      "number": 7,
      "text": "Establish universal code of conduct for school board officials with speech protections and recall procedures",
      "mapping": "-> (Governance)"
    },
    {
      "number": 8,
      "text": "Negotiate sustainable childcare arrangements with federal government under provincial control",
      "mapping": "-> Search for licensed child care; Apply for child care subsidies"
    },
    {
      "number": 9,
      "text": "Improve supports for children with complex learning needs — work with ALSS",
      "mapping": "-> Access special education support"
    },
    {
      "number": 10,
      "text": "Promote high-demand careers through career fairs, counselling websites, and advertising campaigns",
      "mapping": "-> Explore career and technology studies (CTS); Participate in dual credit programs"
    }
  ]
}