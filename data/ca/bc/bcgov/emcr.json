  "mandate_legend": [
    {
      "number": 1,
      "text": "Work with the Minister of Finance to review all existing ministry programs and initiatives to ensure they remain relevant, efficient, grow the economy, and help keep costs low for British Columbians",
      "mapping": "-> Foundational: lead provincial emergency management coordination and planning"
    },
    {
      "number": 2,
      "text": "Support the Minister of Forests to identify ways to mitigate wildfire risk while ensuring a consistent fibre supply to wood product businesses",
      "mapping": "-> Apply for disaster mitigation and community emergency funding"
    },
    {
      "number": 3,
      "text": "Ensure the efficient and effective delivery of emergency services to British Columbians everywhere in the province by leveraging cost-effective technology innovations",
      "mapping": "-> Foundational: lead provincial emergency management coordination and planning"
    },
    {
      "number": 4,
      "text": "Lead cross-ministry coordination to enhance B.C.'s resilience, including through the Climate Preparedness and Adaptation Strategy and the BC Flood Strategy, and seek a more appropriate level of federal support",
      "mapping": "-> Explore climate and disaster hazard maps and data (ClimateReadyBC)"
    },
    {
      "number": 5,
      "text": "Develop provincial and regional hazard risk assessments, including modernized tools for access, to improve transparency, awareness and informed planning and preparedness",
      "mapping": "-> Access the Disaster and Climate Risk and Resilience Assessment (DCRRA)"
    }
  ],
