  "mandate_legend": [
    {
      "number": 1,
      "text": "Work with the Minister of Finance to review all existing ministry programs and initiatives to ensure they remain relevant, efficient, grow the economy, and help keep costs low for British Columbians",
      "mapping": "-> Foundational: report annually on B.C.'s climate change accountability progress"
    },
    {
      "number": 2,
      "text": "Develop ways to ensure costs for energy remain low for people, including through access to home energy retrofits and innovative technology solutions",
      "mapping": "-> Apply for a home energy efficiency rebate"
    },
    {
      "number": 3,
      "text": "Work with BC Hydro, First Nations, and the renewable power industry through frequent competitive calls for power to increase and diversify B.C.'s generation of electricity as the economy continues to grow",
      "mapping": "-> Foundational: plan and oversee provincial electricity system growth and reliability"
    },
    {
      "number": 4,
      "text": "Help grow the profitability and success of B.C.'s clean and low-carbon energy sectors, including advocating against proposed U.S. tariffs, expanding global export markets, and preparing contingency plans for energy exporters",
      "mapping": "-> Bid for petroleum and natural gas tenure rights"
    },
    {
      "number": 5,
      "text": "Work with relevant ministries, First Nations, other governments, project proponents, and key stakeholders to dramatically accelerate permit approval for clean and low-carbon energy infrastructure while preserving environmental standards",
      "mapping": "-> Foundational: plan and oversee provincial electricity system growth and reliability"
    },
    {
      "number": 6,
      "text": "Work with the federal government to cap emissions from the oil and gas sector while attracting investment from producers that use best-in-class emissions reduction technology",
      "mapping": "-> Report your industrial greenhouse gas emissions"
    },
    {
      "number": 7,
      "text": "Ensure BC Hydro is responsive to changing market conditions and demands for large load capacity while protecting residential ratepayers",
      "mapping": "-> Foundational: plan and oversee provincial electricity system growth and reliability"
    },
    {
      "number": 8,
      "text": "Identify innovative ways to help meet carbon emission goals in a manner that reduces cost burdens for B.C. families and businesses, grows the economy, and positions B.C. for trade diversification",
      "mapping": "-> Apply for Clean Industry Fund emissions-reduction funding"
    }
  ],
